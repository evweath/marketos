# ═══════════════════════════════════════════════════════════════
#  MarketOS — Environment Configuration Template
#  Run `bash install.sh` or `node scripts/wizard.js` to set up.
#  The install script copies this to .env.local automatically.
# ═══════════════════════════════════════════════════════════════

# ── App ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3001
APP_ENV=development

# ── Shopify — Store 1 ───────────────────────────────────────────
# Required scopes: read_orders, read_products, read_customers,
#   read_inventory, read_analytics, write_script_tags
SHOPIFY_STORE1_DOMAIN=your-store.myshopify.com
SHOPIFY_STORE1_API_KEY=
SHOPIFY_STORE1_API_SECRET=
SHOPIFY_STORE1_ACCESS_TOKEN=
SHOPIFY_STORE1_WEBHOOK_SECRET=
NEXT_PUBLIC_SHOPIFY_STORE1_NAME=Store 1

# ── Shopify — Store 2 (optional) ────────────────────────────────
SHOPIFY_STORE2_DOMAIN=
SHOPIFY_STORE2_API_KEY=
SHOPIFY_STORE2_API_SECRET=
SHOPIFY_STORE2_ACCESS_TOKEN=
SHOPIFY_STORE2_WEBHOOK_SECRET=
NEXT_PUBLIC_SHOPIFY_STORE2_NAME=Store 2

# ── Shopify — Store 3 (optional) ────────────────────────────────
SHOPIFY_STORE3_DOMAIN=
SHOPIFY_STORE3_API_KEY=
SHOPIFY_STORE3_API_SECRET=
SHOPIFY_STORE3_ACCESS_TOKEN=
SHOPIFY_STORE3_WEBHOOK_SECRET=
NEXT_PUBLIC_SHOPIFY_STORE3_NAME=Store 3

# ── Google Ads ──────────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_MANAGER_ID=

# ── Google Analytics 4 ─────────────────────────────────────────
NEXT_PUBLIC_GA4_MEASUREMENT_ID_STORE1=G-XXXXXXXXXX
NEXT_PUBLIC_GA4_MEASUREMENT_ID_STORE2=G-XXXXXXXXXX
NEXT_PUBLIC_GA4_MEASUREMENT_ID_STORE3=G-XXXXXXXXXX
GA4_PROPERTY_ID_STORE1=
GA4_PROPERTY_ID_STORE2=
GA4_PROPERTY_ID_STORE3=
GA4_SERVICE_ACCOUNT_EMAIL=
GA4_PRIVATE_KEY=

# ── Google Search Console ───────────────────────────────────────
GSC_SERVICE_ACCOUNT_EMAIL=
GSC_PRIVATE_KEY=
GSC_SITE_URL_STORE1=https://your-store1.com
GSC_SITE_URL_STORE2=
GSC_SITE_URL_STORE3=

# ── Google Enhanced Conversions ─────────────────────────────────
GOOGLE_ENHANCED_CONVERSION_ID=
GOOGLE_ENHANCED_CONVERSION_LABEL=

# ── Meta (Facebook & Instagram) ─────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_XXXXXXXXXXXXXXXXX

# ── Meta Pixel & CAPI ───────────────────────────────────────────
NEXT_PUBLIC_META_PIXEL_ID_STORE1=
NEXT_PUBLIC_META_PIXEL_ID_STORE2=
NEXT_PUBLIC_META_PIXEL_ID_STORE3=
META_CAPI_ACCESS_TOKEN=
META_CAPI_TEST_EVENT_CODE=

# ── TikTok Ads ──────────────────────────────────────────────────
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=

# ── YouTube ─────────────────────────────────────────────────────
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID_STORE1=
YOUTUBE_CHANNEL_ID_STORE2=
YOUTUBE_CHANNEL_ID_STORE3=

# ── X / Twitter Ads ─────────────────────────────────────────────
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_AD_ACCOUNT_ID=

# ── LinkedIn Ads ────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AD_ACCOUNT_ID=

# ── Klaviyo ──────────────────────────────────────────────────────
KLAVIYO_API_KEY=
KLAVIYO_LIST_ID_STORE1=
KLAVIYO_LIST_ID_STORE2=
KLAVIYO_LIST_ID_STORE3=

# ── HubSpot (optional) ──────────────────────────────────────────
HUBSPOT_API_KEY=
HUBSPOT_PORTAL_ID=

# ── Salesforce (optional) ───────────────────────────────────────
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=

# ── Slack ────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=
SLACK_ALERT_CHANNEL=#marketing-alerts
SLACK_REPORT_CHANNEL=#marketing-reports

# ── Microsoft Teams ──────────────────────────────────────────────
TEAMS_WEBHOOK_URL=

# ── Zapier ───────────────────────────────────────────────────────
ZAPIER_WEBHOOK_URL=

# ── Make / Integromat ────────────────────────────────────────────
MAKE_WEBHOOK_URL=

# ── Canva (optional) ─────────────────────────────────────────────
CANVA_API_KEY=

# ── SMS Provider ─────────────────────────────────────────────────
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Web Push (VAPID) ─────────────────────────────────────────────
# Generate keys: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourstore.com
